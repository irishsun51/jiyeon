   "source": [
    "###[전처리 3] 결측치 처리\n",
    "수치형은 중앙값(median), 범주형은 최빈값(mode)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 45,
   "id": "d5ceb0a3-cc11-4917-b228-3b755a49fe14",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ 모든 결측치 처리 완료\n"
     ]
    }
   ],
   "source": [
    "for col in data.columns:\n",
    "    if data[col].dtype in ['float64', 'int64']:\n",
    "        data[col] = data[col].fillna(data[col].median())\n",
    "    else:\n",
    "        data[col] = data[col].fillna(data[col].mode()[0])\n",
    "print(\"✅ 모든 결측치 처리 완료\")"
   ]
  },
